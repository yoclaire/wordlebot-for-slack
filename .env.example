# Slack Bot Token (xoxb-...)
# Bot token scopes needed: channels:history, channels:read, chat:write,
# commands, reactions:write, users:read
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token (xapp-...)
# Required for Socket Mode — generate under Basic Information > App-Level Tokens
# with the "connections:write" scope
SLACK_APP_TOKEN=xapp-your-app-token

# Timezone (optional, defaults to America/New_York)
# TZ=America/New_York
